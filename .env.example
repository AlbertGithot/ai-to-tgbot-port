BOT_TOKEN=your_telegram_bot_token
MODEL_PATH=./models/model.gguf
LLAMA_CPP_DIR=./llama.cpp
LLAMA_SERVER_EXE=./llama.cpp/llama-server
SOURCE_URL=https://github.com/AlbertGithot/ai-to-tgbot-port

LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8080
LLAMA_SERVER_START_TIMEOUT=180
LLAMA_SERVER_REASONING=off
LLAMA_SERVER_REASONING_BUDGET=0
LLAMA_SERVER_REASONING_FORMAT=deepseek
LLAMA_SERVER_AUTO_RESTART=true
LLAMA_SERVER_MAX_RESTART_ATTEMPTS=1
LLAMA_SERVER_RESTART_DELAY_SECONDS=2
SITE_DASHBOARD_HOST=127.0.0.1
SITE_DASHBOARD_PORT=5080
SITE_DASHBOARD_REFRESH_SECONDS=4

CHAT_FORMAT=qwen
MAX_HISTORY_MESSAGES=10
MAX_HISTORY_ENTRY_CHARS=2500
MAX_ACTIVE_DIALOGS=200
MAX_USER_TEXT_CHARS=6000
MAX_MULTI_REQUEST_TEXT_CHARS=2000
MAX_LOG_TEXT_CHARS=6000
MAX_MODEL_REPLY_CHARS=24000
N_THREADS=4
N_CTX=32768
N_BATCH=512
N_GPU_LAYERS=0
MAX_TOKENS=3072
BRIEF_MAX_TOKENS=240
TEMPERATURE=0.5
TOP_P=0.95
TOP_K=20
REPEAT_PENALTY=1.1
TELEGRAM_SEGMENT_LIMIT=3800
SHOW_MODEL_RAW=true
USE_RAW_MODEL_REPLY=true
ENABLE_REPAIR_PASS=true
AI_ENABLED=true
MAX_TRACKED_BOT_MESSAGES=80
